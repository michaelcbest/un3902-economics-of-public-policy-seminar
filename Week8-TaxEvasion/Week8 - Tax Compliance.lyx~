\begin_deeper
\begin_layout Itemize
Tax evasion:
 misreporting tax liability in an 
\emph on
illegal
\emph default
 way
\begin_inset VSpace medskip
\end_inset


\end_layout

\begin_layout Itemize
Tax avoidance:
 exploiting loopholes to minimize tax liability,
 
\emph on
without
\emph default
